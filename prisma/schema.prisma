datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Cuenta {
  id        String   @id @default(uuid())
  nombre    String
  tipo      String   // PERSONAL, EMPRESA
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  deletedBy String?

  organizaciones Organizacion[]
}

model Organizacion {
  id                       String   @id @default(uuid())
  nombre                   String
  cuentaId                 String
  cuenta                   Cuenta   @relation(fields: [cuentaId], references: [id])
  identificacionTributaria String?  // NIT / RUC
  direccion                String?
  telefono                 String?
  configuracion            Json?    // Configuración del wizard (moneda, finanzas, rutas, etc.)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  deletedAt                DateTime?
  deletedBy                String?

  usuarios  Usuario[]
  clientes  Cliente[]
  cajas     Caja[]
  rutas     Ruta[]
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

model Ruta {
  id             String       @id @default(cuid())
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)

  /// Nombre visible de la ruta
  /// Ej: "Santo Domingo"
  nombre         String

  /// Código opcional
  /// Ej: SD-LUN
  codigo         String?      @unique

  /// Zona o sector donde se trabaja
  zona           String?

  /// Día habitual de trabajo
  diaSemana      DiaSemana

  /// Usuario responsable de la ruta
  responsableId  String?
  responsable    Usuario?     @relation(fields: [responsableId], references: [id])

  /// Color para identificar la ruta en la app
  color          String?

  descripcion    String?

  activa         Boolean      @default(true)

  clientes       Cliente[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  deletedBy      String?
}

model Rol {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarios    Usuario[]
}

model Usuario {
  id             String       @id @default(uuid())
  nombre         String
  email          String       @unique
  password       String
  rolId          String
  rol            Rol          @relation(fields: [rolId], references: [id])
  organizacionId String?
  organizacion   Organizacion? @relation(fields: [organizacionId], references: [id])
  rutas          Ruta[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  deletedBy      String?

  auditorias     Auditoria[]
}

model Cliente {
  id             String       @id @default(uuid())
  nombre         String
  identificacion String       @unique
  telefono       String?
  direccion      String?
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])
  rutaId         String?
  ruta           Ruta?        @relation(fields: [rutaId], references: [id])
  estado         String       @default("ACTIVO")

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  deletedBy      String?

  prestamos      Prestamo[]
}

model Prestamo {
  id               String       @id @default(uuid())
  clienteId        String
  cliente          Cliente      @relation(fields: [clienteId], references: [id])
  monto            Decimal      @db.Decimal(12, 2)
  tasaInteres      Decimal      @db.Decimal(5, 2) // Porcentaje
  plazo            Int          // Cantidad de cuotas
  estado           String       // PENDIENTE, ACTIVO, PAGADO, VENCIDO, ANULADO
  fechaInicio      DateTime
  fechaVencimiento DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  cuotas           Cuota[]
  pagos            Pago[]
}

model Cuota {
  id               String   @id @default(uuid())
  prestamoId       String
  prestamo         Prestamo @relation(fields: [prestamoId], references: [id])
  numeroCuota      Int
  montoPrincipal   Decimal  @db.Decimal(12, 2)
  montoInteres     Decimal  @db.Decimal(12, 2)
  montoTotal       Decimal  @db.Decimal(12, 2)
  montoPagado      Decimal  @db.Decimal(12, 2) @default(0)
  fechaVencimiento DateTime
  fechaPago        DateTime?
  estado           String   // PENDIENTE, PARCIAL, PAGADO, VENCIDO
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Pago {
  id         String    @id @default(uuid())
  prestamoId String
  prestamo   Prestamo  @relation(fields: [prestamoId], references: [id])
  monto      Decimal   @db.Decimal(12, 2)
  fechaPago  DateTime  @default(now())
  cajaId     String?
  caja       Caja?     @relation(fields: [cajaId], references: [id])
  metodoPago String    // EFECTIVO, TRANSFERENCIA, etc.
  referencia String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  deletedBy  String?
}

model Caja {
  id             String       @id @default(uuid())
  nombre         String
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])
  montoApertura  Decimal      @db.Decimal(12, 2)
  montoCierre    Decimal?     @db.Decimal(12, 2)
  fechaApertura  DateTime     @default(now())
  fechaCierre    DateTime?
  estado         String       // ABIERTA, CERRADA
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  deletedBy      String?

  pagos          Pago[]
  movimientos    MovimientoCaja[]
  gastos         Gasto[]
}

model MovimientoCaja {
  id          String   @id @default(uuid())
  cajaId      String
  caja        Caja     @relation(fields: [cajaId], references: [id])
  tipo        String   // INGRESO, EGRESO
  monto       Decimal  @db.Decimal(12, 2)
  descripcion String
  createdAt   DateTime @default(now())
}

model Gasto {
  id          String   @id @default(uuid())
  cajaId      String
  caja        Caja     @relation(fields: [cajaId], references: [id])
  monto       Decimal  @db.Decimal(12, 2)
  descripcion String
  fechaGasto  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?
}

model Auditoria {
  id                String   @id @default(uuid())
  usuarioId         String?
  usuario           Usuario? @relation(fields: [usuarioId], references: [id])
  accion            String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  tabla             String
  registroId        String?
  valoresAnteriores Json?
  valoresNuevos     Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
}

model Sincronizacion {
  id             String   @id @default(uuid())
  dispositivoId  String
  ultimoSincroAt DateTime
  tabla          String
  createdAt      DateTime @default(now())
}
