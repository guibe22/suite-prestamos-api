datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Cuenta {
  id        String    @id @default(uuid())
  nombre    String
  tipo      String // PERSONAL, EMPRESA
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy String?

  organizaciones Organizacion[]
}

model Organizacion {
  id                       String    @id @default(uuid())
  nombre                   String
  cuentaId                 String
  cuenta                   Cuenta    @relation(fields: [cuentaId], references: [id])
  identificacionTributaria String? // NIT / RUC
  direccion                String?
  telefono                 String?
  configuracion            Json? // Configuración del wizard (moneda, finanzas, rutas, etc.)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?
  deletedBy                String?

  usuarios Usuario[]
  clientes Cliente[]
  cajas    Caja[]
  rutas    Ruta[]
  jornadas JornadaCobranza[]
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

model Ruta {
  id             String       @id @default(cuid())
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)

  /// Nombre visible de la ruta
  /// Ej: "Santo Domingo"
  nombre String

  /// Código opcional
  /// Ej: SD-LUN
  codigo String?

  /// Zona o sector donde se trabaja
  zona String?

  /// Día habitual de trabajo
  diaSemana DiaSemana

  /// Usuario responsable de la ruta
  responsableId String?
  responsable   Usuario? @relation(fields: [responsableId], references: [id])

  /// Color para identificar la ruta en la app
  color String?

  descripcion String?

  activa Boolean @default(true)

  clientes Cliente[]
  jornadas JornadaCobranza[]

  /// Colaboradores adicionales de la ruta (aparte del responsable principal)
  /// con el mismo acceso operativo que el responsable.
  colaboradores RutaColaborador[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy String?

  @@unique([organizacionId, codigo])
}

/// Colaborador adicional asignado a una ruta, además del responsable
/// principal (Ruta.responsableId). Gestionar esta tabla es una decisión
/// administrativa (ver sincronizacion.service.ts): solo ADMIN/SUPER_ADMIN
/// puede crear o eliminar filas vía sync.
model RutaColaborador {
  id        String    @id @default(cuid())
  rutaId    String
  ruta      Ruta      @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy String?

  @@unique([rutaId, usuarioId])
}

model Rol {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarios Usuario[]
}

model Usuario {
  id               String            @id @default(uuid())
  nombre           String
  email            String            @unique
  // Nulo mientras la invitación no ha sido aceptada: el miembro invitado
  // define su propia contraseña al aceptar, el ADMIN nunca la fija.
  password         String?
  rolId            String
  rol              Rol               @relation(fields: [rolId], references: [id])
  organizacionId   String?
  organizacion     Organizacion?     @relation(fields: [organizacionId], references: [id])
  rutas            Ruta[]
  rutasColaborador RutaColaborador[]
  jornadas         JornadaCobranza[]
  cajas            Caja[]
  prestamos        Prestamo[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  // Invitación al equipo: mientras invitacionAceptadaEn sea nulo, el usuario
  // no puede iniciar sesión (no ha confirmado que quiere unirse ni fijado
  // contraseña). Nulos en todos estos campos = cuenta creada sin invitación
  // (registro directo del dueño de la organización).
  invitacionToken      String?   @unique
  invitacionExpiraEn   DateTime?
  invitacionAceptadaEn DateTime?

  auditorias Auditoria[]
}

enum EstadoCliente {
  ACTIVO
  INACTIVO
  SUSPENDIDO
  BLOQUEADO
}

enum NivelRiesgo {
  BAJO
  MEDIO
  ALTO
}

enum CalificacionCliente {
  EXCELENTE
  BUENO
  REGULAR
  RIESGOSO
  BLOQUEADO
}

enum Sexo {
  MASCULINO
  FEMENINO
  OTRO
}

model Cliente {
  id String @id @default(uuid())

  // Organización
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)

  // Ruta
  rutaId String
  ruta   Ruta   @relation(fields: [rutaId], references: [id])

  // Identificación interna
  codigo String

  // Datos personales
  nombres         String
  apellidos       String?
  identificacion  String?
  fechaNacimiento DateTime?
  sexo            Sexo?

  // Contacto
  telefono  String
  telefono2 String?
  correo    String?

  // Dirección
  direccion  String
  sector     String?
  ciudad     String?
  provincia  String?
  referencia String?

  // Geolocalización
  latitud  Float?
  longitud Float?

  // Información laboral
  empresa           String?
  ocupacion         String?
  ingresosMensuales Decimal? @db.Decimal(12, 2)

  // Perfil financiero: valores de negocio recalculados por eventos
  // (pago puntual, atraso, renovación). Los agregados (total prestado,
  // mora acumulada, etc.) NO se guardan aquí: se derivan de Prestamo/Pago.
  puntuacion   Int                 @default(100)
  nivelRiesgo  NivelRiesgo         @default(BAJO)
  calificacion CalificacionCliente @default(BUENO)

  // Organización de la ruta
  ordenRuta Int @default(0)

  // Estado
  estado EstadoCliente @default(ACTIVO)

  // Notas internas
  observaciones String?

  // Auditoría
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy String?

  // Relaciones
  prestamos   Prestamo[]
  referencias ReferenciaCliente[]
  avales      Aval[]
  documentos  DocumentoCliente[]

  @@unique([organizacionId, codigo])
  @@unique([organizacionId, identificacion])
  @@index([organizacionId])
  @@index([rutaId])
  @@index([telefono])
  @@index([estado])
  @@index([calificacion])
  @@index([nivelRiesgo])
}

model ReferenciaCliente {
  id String @id @default(uuid())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  nombre     String
  parentesco String?
  telefono   String
  direccion  String?

  createdAt DateTime @default(now())
}

model Aval {
  id String @id @default(uuid())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  nombre         String
  identificacion String?
  telefono       String
  direccion      String?
  parentesco     String?

  createdAt DateTime @default(now())
}

enum TipoDocumento {
  CEDULA_FRENTE
  CEDULA_REVERSO
  CONTRATO
  FOTO_CLIENTE
  FOTO_VIVIENDA
  FOTO_NEGOCIO
  OTRO
}

model DocumentoCliente {
  id String @id @default(uuid())

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  tipo TipoDocumento

  nombre  String
  archivo String

  createdAt DateTime @default(now())
}

model Prestamo {
  id               String    @id @default(uuid())
  clienteId        String
  cliente          Cliente   @relation(fields: [clienteId], references: [id])
  // Cobrador que desembolsó el préstamo. Sin esto, "préstamos entregados hoy"
  // en el cálculo de caja solo podía filtrarse por fecha y contaminaba el
  // balance de un cobrador con desembolsos de otros el mismo día.
  usuarioId        String?
  usuario          Usuario?  @relation(fields: [usuarioId], references: [id])
  monto            Decimal   @db.Decimal(12, 2)
  tasaInteres      Decimal   @db.Decimal(5, 2) // Porcentaje
  plazo            Int // Cantidad de cuotas
  // Valores reales que escribe la app móvil: ACTIVO, LIQUIDADO (MOROSO,
  // VENCIDO, RENOVABLE y ATRASADO son estados VISUALES derivados en el
  // cliente, nunca persistidos aquí).
  estado           String // ACTIVO, LIQUIDADO
  fechaInicio      DateTime
  fechaVencimiento DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  cuotas Cuota[]
  pagos  Pago[]
}

model Cuota {
  id               String    @id @default(uuid())
  prestamoId       String
  prestamo         Prestamo  @relation(fields: [prestamoId], references: [id])
  numeroCuota      Int
  montoPrincipal   Decimal   @db.Decimal(12, 2)
  montoInteres     Decimal   @db.Decimal(12, 2)
  montoTotal       Decimal   @db.Decimal(12, 2)
  montoPagado      Decimal   @default(0) @db.Decimal(12, 2)
  fechaVencimiento DateTime
  fechaPago        DateTime?
  // Valores reales que escribe la app móvil: PENDIENTE, PAGADA (binario; un
  // abono parcial deja la cuota en PENDIENTE con montoPagado > 0, la app no
  // usa un estado intermedio).
  estado           String // PENDIENTE, PAGADA
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  deletedBy        String?
}

model Pago {
  id         String           @id @default(uuid())
  prestamoId String
  prestamo   Prestamo         @relation(fields: [prestamoId], references: [id])
  monto      Decimal          @db.Decimal(12, 2)
  fechaPago  DateTime         @default(now())
  cajaId     String?
  caja       Caja?            @relation(fields: [cajaId], references: [id])
  // A qué jornada de cobro pertenece este pago (para poder listar/detallar
  // los ingresos de una jornada concreta, igual que Gasto.jornadaId).
  jornadaId  String?
  jornada    JornadaCobranza? @relation(fields: [jornadaId], references: [id], onDelete: SetNull)
  metodoPago String // EFECTIVO, TRANSFERENCIA, etc.
  referencia String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?
  deletedBy  String?
}

model Caja {
  id             String       @id @default(uuid())
  nombre         String
  organizacionId String
  organizacion   Organizacion @relation(fields: [organizacionId], references: [id])
  // A qué cobrador pertenece esta caja. Sin esto, dos cobradores con jornada
  // abierta el mismo día no se pueden distinguir por "caja ABIERTA de mi
  // organización" y sus cobros/gastos terminan mezclados entre cuadres.
  usuarioId      String?
  usuario        Usuario?     @relation(fields: [usuarioId], references: [id])
  montoApertura  Decimal      @db.Decimal(12, 2)
  montoCierre    Decimal?     @db.Decimal(12, 2)
  fechaApertura  DateTime     @default(now())
  fechaCierre    DateTime?
  estado         String // ABIERTA, CERRADA
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  deletedBy      String?

  pagos       Pago[]
  movimientos MovimientoCaja[]
  gastos      Gasto[]
}

model MovimientoCaja {
  id          String   @id @default(uuid())
  cajaId      String
  caja        Caja     @relation(fields: [cajaId], references: [id])
  tipo        String // INGRESO, EGRESO
  monto       Decimal  @db.Decimal(12, 2)
  descripcion String
  createdAt   DateTime @default(now())
}

model Gasto {
  id          String           @id @default(uuid())
  cajaId      String
  caja        Caja             @relation(fields: [cajaId], references: [id])
  jornadaId   String?
  jornada     JornadaCobranza? @relation(fields: [jornadaId], references: [id], onDelete: SetNull)
  categoria   String?
  monto       Decimal          @db.Decimal(12, 2)
  descripcion String
  fechaGasto  DateTime         @default(now())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  deletedBy   String?
}

model Auditoria {
  id                String   @id @default(uuid())
  usuarioId         String?
  usuario           Usuario? @relation(fields: [usuarioId], references: [id])
  accion            String // CREATE, UPDATE, DELETE, LOGIN, etc.
  tabla             String
  registroId        String?
  valoresAnteriores Json?
  valoresNuevos     Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
}

model Sincronizacion {
  id             String   @id @default(uuid())
  dispositivoId  String
  ultimoSincroAt DateTime
  tabla          String
  createdAt      DateTime @default(now())
}

enum EstadoJornada {
  ABIERTA
  CERRADA
}

model JornadaCobranza {
  id                 String        @id @default(uuid())
  organizacionId     String
  organizacion       Organizacion  @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  usuarioId          String
  usuario            Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rutaId             String
  ruta               Ruta          @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  fecha              DateTime
  saldoInicial       Decimal       @db.Decimal(12, 2)
  saldoFinal         Decimal?      @db.Decimal(12, 2)
  efectivoCobrado    Decimal       @default(0) @db.Decimal(12, 2)
  prestamos          Decimal       @default(0) @db.Decimal(12, 2)
  gastos             Decimal       @default(0) @db.Decimal(12, 2)
  // Progreso en vivo de la ronda: cuántos clientes de la ruta ya se
  // atendieron (cobrados, sin cobro o pospuestos) vs. cuántos faltan. Se
  // actualiza en cada cambio mientras la jornada sigue ABIERTA, para que un
  // ADMIN/CAJERO pueda monitorear el avance de otros cobradores en tiempo real.
  clientesVisitados  Int           @default(0)
  clientesPendientes Int           @default(0)
  estado             EstadoJornada @default(ABIERTA)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
  deletedBy          String?

  detallesGastos Gasto[]
  pagos          Pago[]

  @@map("jornadas_cobranza")
}
