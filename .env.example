# Servidor
PORT=3020
NODE_ENV=development

# Base de Datos PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/suite_prestamos?schema=public"

# Seguridad / JWT (mínimo 32 caracteres; usar valores aleatorios reales en producción)
JWT_SECRET="genera-un-secreto-aleatorio-de-al-menos-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="genera-otro-secreto-aleatorio-de-al-menos-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# Logging
LOG_LEVEL="info"

# Resend Email Verification
RESEND_API_KEY=""
RESEND_FROM="Suite Préstamos <onboarding@resend.dev>"

# CORS (orígenes permitidos separados por coma, requerido en producción)
CORS_ORIGINS="https://app.tudominio.com"

# Suscripciones / monetización
# En "false" (default), requireActiveSubscription() no bloquea nada — activar
# por ambiente solo cuando PayPal y Google Play estén verificados.
SUBSCRIPTIONS_ENFORCEMENT_ENABLED="false"

# PayPal Subscriptions (web)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_MODE="sandbox"

# Google Play Billing (Android) — JSON completo de la service account con
# acceso a la Play Developer API, y el nombre de paquete de la app.
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_PLAY_PACKAGE_NAME=""
