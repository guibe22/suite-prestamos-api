# Servidor
PORT=3020
NODE_ENV=development

# Base de Datos PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/suite_prestamos?schema=public"

# Seguridad / JWT (mínimo 32 caracteres; usar valores aleatorios reales en producción)
JWT_SECRET="genera-un-secreto-aleatorio-de-al-menos-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="genera-otro-secreto-aleatorio-de-al-menos-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# Logging
LOG_LEVEL="info"

# Resend Email Verification
RESEND_API_KEY=""
RESEND_FROM="Suite Préstamos <onboarding@resend.dev>"

# CORS (orígenes permitidos separados por coma, requerido en producción)
CORS_ORIGINS="https://app.tudominio.com"

# Suscripciones / monetización
# El enforcement (bloquear o no según el estado de la suscripción) ya NO es
# una env var: es un toggle en la tabla ConfiguracionSistema, editable desde
# el panel admin (SUPER_ADMIN > Ajustes) sin redeploy.

# RevenueCat (Android + Web unificados) — secreto del webhook configurado en
# el dashboard de RevenueCat (Project settings > Integrations > Webhooks).
REVENUECAT_WEBHOOK_SECRET=""
# API key pública de Android de RevenueCat — vive aquí (no en el build de la
# app) para que rotarla no requiera subir una app nueva; el cliente la pide
# en caliente vía GET /suscripcion/config.
REVENUECAT_ANDROID_API_KEY=""
